#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage:
  openmax-tmux start <name> <project-dir> <prompt>
  openmax-tmux status <name>
  openmax-tmux wait <name>
  openmax-tmux capture <name>
  openmax-tmux attach <name>
  openmax-tmux stop <name>
  openmax-tmux list
EOF
  exit 2
}

die() {
  printf 'openmax-tmux: %s\n' "$*" >&2
  exit 2
}

require_tmux() {
  command -v tmux >/dev/null 2>&1 || die "tmux is required"
}

validate_name() {
  [[ ${1:-} =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]{0,63}$ ]] ||
    die "name must match [a-zA-Z0-9][a-zA-Z0-9._-]{0,63}"
}

state_root=${OPENMAX_DELEGATE_DIR:-"$HOME/.openmax/delegates"}

logical_link() {
  printf '%s/names/%s' "$state_root" "$1"
}

resolve_generation() {
  local link
  link=$(logical_link "$1")
  [[ -L $link ]] || die "unknown delegate: $1"
  (
    cd -P "$(dirname "$link")"
    cd -P -- "$(readlink "$link")"
    pwd -P
  )
}

read_state_value() {
  local generation=$1
  local key=$2
  [[ -f $generation/$key ]] || die "delegate state is incomplete: $generation/$key"
  IFS= read -r REPLY <"$generation/$key" || true
  printf '%s' "$REPLY"
}

exact_target() {
  printf '=%s' "$1"
}

exact_window_target() {
  printf '=%s:' "$1"
}

start_delegate() {
  [[ $# -eq 3 ]] || usage
  local name=$1
  local project_input=$2
  local prompt=$3
  validate_name "$name"
  require_tmux
  [[ -d $project_input ]] || die "project directory does not exist: $project_input"

  local project
  project=$(cd -P -- "$project_input" && pwd -P)
  local openmax_bin=${OPENMAX_BIN:-openmax}
  if [[ $openmax_bin == */* ]]; then
    [[ -x $openmax_bin ]] || die "OPENMAX_BIN is not executable: $openmax_bin"
    openmax_bin=$(cd -P -- "$(dirname "$openmax_bin")" && pwd -P)/$(basename "$openmax_bin")
  else
    openmax_bin=$(command -v "$openmax_bin") || die "openmax executable not found: ${OPENMAX_BIN:-openmax}"
  fi

  mkdir -p "$state_root/generations" "$state_root/names"
  local generation_id
  generation_id=$(date -u +%Y%m%dT%H%M%S)-$$
  local generation="$state_root/generations/$name-$generation_id"
  local suffix=0
  while ! mkdir "$generation" 2>/dev/null; do
    suffix=$((suffix + 1))
    generation="$state_root/generations/$name-$generation_id-$suffix"
  done

  local session="openmax-delegate-$name-$generation_id"
  local channel="openmax-delegate-done-$name-$generation_id"
  printf '%s' "$prompt" >"$generation/prompt"
  printf '%s\n' "$project" >"$generation/project"
  printf '%s\n' "$session" >"$generation/session"
  printf '%s\n' "$channel" >"$generation/channel"
  printf '%s\n' "$openmax_bin" >"$generation/openmax-bin"

  local quoted_project quoted_bin quoted_prompt quoted_output quoted_exit quoted_channel
  printf -v quoted_project '%q' "$project"
  printf -v quoted_bin '%q' "$openmax_bin"
  printf -v quoted_prompt '%q' "$generation/prompt"
  printf -v quoted_output '%q' "$generation/output.log"
  printf -v quoted_exit '%q' "$generation/exit-code"
  printf -v quoted_channel '%q' "$channel"

  tmux wait-for -L "$channel"
  local command
  command="tmux set-option -w -t =$session: remain-on-exit on; cd $quoted_project && $quoted_bin --trust-project -p \"\$(cat $quoted_prompt)\" >$quoted_output 2>&1; code=\$?; tmp=$quoted_exit.tmp.\$\$; printf '%s\\n' \"\$code\" >\"\$tmp\"; mv \"\$tmp\" $quoted_exit; tmux wait-for -U $quoted_channel; exit \"\$code\""
  if ! tmux new-session -d -s "$session" /bin/sh -c "$command"; then
    tmux wait-for -U "$channel" >/dev/null 2>&1 || true
    die "failed to create tmux session: $session"
  fi

  local link temporary_link
  link=$(logical_link "$name")
  temporary_link="$state_root/names/.${name}.${generation_id}.$$"
  ln -s "../generations/$(basename "$generation")" "$temporary_link"
  if mv -Tf "$temporary_link" "$link" 2>/dev/null; then
    :
  elif mv -fh "$temporary_link" "$link" 2>/dev/null; then
    :
  else
    die "could not atomically update delegate link: $link"
  fi
  printf '%s\n' "$generation"
}

status_delegate() {
  [[ $# -eq 1 ]] || usage
  local generation session
  generation=$(resolve_generation "$1")
  session=$(read_state_value "$generation" session)
  if [[ -f $generation/exit-code ]]; then
    printf 'exited %s\n' "$(read_state_value "$generation" exit-code)"
  elif tmux has-session -t "$(exact_target "$session")" 2>/dev/null; then
    printf 'running\n'
  else
    printf 'lost\n'
    return 1
  fi
}

wait_delegate() {
  [[ $# -eq 1 ]] || usage
  require_tmux
  local generation session channel
  generation=$(resolve_generation "$1")
  session=$(read_state_value "$generation" session)
  channel=$(read_state_value "$generation" channel)
  if [[ ! -f $generation/exit-code ]]; then
    if ! tmux has-session -t "$(exact_target "$session")" 2>/dev/null; then
      die "delegate session disappeared before recording an exit code"
    fi
    tmux wait-for -L "$channel"
    tmux wait-for -U "$channel"
  fi
  local code
  code=$(read_state_value "$generation" exit-code)
  printf '%s\n' "$code"
  return "$code"
}

capture_delegate() {
  [[ $# -eq 1 ]] || usage
  local generation session
  generation=$(resolve_generation "$1")
  session=$(read_state_value "$generation" session)
  if [[ -f $generation/output.log ]]; then
    cat "$generation/output.log"
  elif tmux has-session -t "$(exact_target "$session")" 2>/dev/null; then
    tmux capture-pane -p -t "$(exact_window_target "$session")"
  fi
}

attach_delegate() {
  [[ $# -eq 1 ]] || usage
  require_tmux
  local generation session
  generation=$(resolve_generation "$1")
  session=$(read_state_value "$generation" session)
  exec tmux attach-session -t "$(exact_target "$session")"
}

stop_delegate() {
  [[ $# -eq 1 ]] || usage
  require_tmux
  local generation session channel
  generation=$(resolve_generation "$1")
  session=$(read_state_value "$generation" session)
  channel=$(read_state_value "$generation" channel)
  if tmux has-session -t "$(exact_target "$session")" 2>/dev/null; then
    tmux kill-session -t "$(exact_target "$session")"
  fi
  if [[ ! -f $generation/exit-code ]]; then
    local temporary="$generation/exit-code.tmp.$$"
    printf '143\n' >"$temporary"
    mv "$temporary" "$generation/exit-code"
    tmux wait-for -U "$channel" >/dev/null 2>&1 || true
  fi
  printf 'stopped\n'
}

list_delegates() {
  [[ $# -eq 0 ]] || usage
  [[ -d $state_root/names ]] || return 0
  local link name generation status
  for link in "$state_root"/names/*; do
    [[ -L $link ]] || continue
    name=$(basename "$link")
    generation=$(resolve_generation "$name")
    status=$(status_delegate "$name" 2>/dev/null || true)
    printf '%s\t%s\t%s\n' "$name" "$status" "$generation"
  done
}

action=${1:-}
[[ -n $action ]] || usage
shift
case "$action" in
  start) start_delegate "$@" ;;
  status) status_delegate "$@" ;;
  wait) wait_delegate "$@" ;;
  capture) capture_delegate "$@" ;;
  attach) attach_delegate "$@" ;;
  stop) stop_delegate "$@" ;;
  list) list_delegates "$@" ;;
  *) usage ;;
esac
